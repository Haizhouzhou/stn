# ============================================================
# STN beta-burst / DYNAP-SE1 project
# Keep source, docs, configs, tests, small audits/results tracked.
# Never track raw data, local environments, caches, or huge binaries.
# ============================================================

# Raw / original data: never push
raw/

# Local Python / conda environments
stn_env/
stn_env_corrupted/
.venv/
venv/
env/
ENV/
*.egg-info/

# Python caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Jupyter / editor / OS noise
.ipynb_checkpoints/
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Temporary / partial transfer files
*.tmp
*.temp
*.part
*.bak
*.orig

# Cluster transient files that are usually not scientific artifacts
core.*

# Auto-excluded files >=95MB; GitHub ordinary Git rejects >=100MB
